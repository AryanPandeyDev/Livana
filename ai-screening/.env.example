# AI Screening Service — environment configuration
# Copy this file to `.env` and fill in real values for local development.

# Where the AI service POSTs screening results back to the Backend.
# This is the Backend's internal callback endpoint.
BACKEND_CALLBACK_URL=http://localhost:8080/api/v1/internal/screening-callback

# Mutual shared secret used as the X-Internal-Secret header in BOTH directions
# (Backend -> AI /screen and AI -> Backend /screening-callback).
# Must match the Backend's ai-screening.shared-secret value.
SHARED_SECRET=change-me-shared-secret

# IPFS gateway base URL used to fetch application documents (trailing slash).
IPFS_GATEWAY_URL=https://gateway.pinata.cloud/ipfs/

# Maximum number of files fetched from a directory CID.
MAX_DOCUMENT_FILES=5

# Maximum bytes fetched per document file (default 10 MB).
MAX_DOCUMENT_BYTES=10485760

# Gemini model id used for synthesis and structured output.
GEMINI_MODEL=gemini-2.0-flash

# Platform infrastructure Tavily key for web search.
# NOT admin-managed and never sent over the wire.
TAVILY_API_KEY=tvly-your-tavily-key

# NOTE: The Gemini API key is NOT configured here. It arrives per-request in the
# /screen request body (decrypted and forwarded by the Backend) and is used only
# for that single run, then discarded.
