# Livana — root Docker Compose environment
#
# Copy this file to `.env` and fill in real values for local development.
# Docker Compose loads `.env` from this directory automatically and substitutes
# the `${VAR}` references in docker-compose.yml.

# --- Mutual shared secret (backend <-> ai-screening) ---
# Used as the X-Internal-Secret header in BOTH directions. The backend reads it
# as AI_SCREENING_SHARED_SECRET and the ai-screening service reads it as
# SHARED_SECRET; compose wires the SAME value into both, so they always match.
AI_SCREENING_SHARED_SECRET=change-me-shared-secret

# --- AI config encryption key ---
# Base64-encoded 256-bit (32-byte) AES key used by the backend to encrypt the
# Gemini API key at rest. Generate one, e.g.:
#   openssl rand -base64 32
AI_CONFIG_ENCRYPTION_KEY=change-me-base64-32-byte-key

# --- Clerk ---
# Clerk Backend API secret key (sk_...) for server-to-server calls.
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# --- Tavily ---
# Platform infrastructure Tavily key used by the ai-screening service for web
# search. Never sent over the wire / never admin-managed.
TAVILY_API_KEY=tvly-your-tavily-key

# --- Database ---
# Credentials for the local postgres service (database name is `livana`).
DB_USERNAME=postgres
DB_PASSWORD=postgres

# --- Optional ai-screening overrides (defaults are set in docker-compose.yml) ---
# IPFS_GATEWAY_URL=https://gateway.pinata.cloud/ipfs/
# MAX_DOCUMENT_FILES=5
# MAX_DOCUMENT_BYTES=10485760
# GEMINI_MODEL=gemini-2.0-flash
